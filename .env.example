# =============================================================================
# AXTO.dev — environment configuration
# In production these are populated from GitHub Secrets / Cloudflare Pages
# environment variables. Never commit a real .env file.
# =============================================================================

# --- App -----------------------------------------------------------------
NEXT_PUBLIC_APP_URL="https://axto.dev"
NEXT_PUBLIC_APP_NAME="AXTO.dev"
NODE_ENV="development"

# --- Database (Cloudflare D1) ---------------------------------------------
# Provisioned via GitHub Secrets: CLOUDFLARE_ACCOUNT_ID, CLOUDFLARE_API_TOKEN,
# CLOUDFLARE_D1_DATABASE_ID. Local dev falls back to a SQLite file.
DATABASE_URL="file:./dev.db"

# --- Better Auth ------------------------------------------------------------
BETTER_AUTH_SECRET="replace-with-32-byte-random-secret"
BETTER_AUTH_URL="http://localhost:3000"

# --- Cloudflare R2 (object storage for e-book files) ------------------------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_EBOOKS_BUCKET="axto-dev-ebooks"
R2_ASSETS_BUCKET="axto-dev-assets"
R2_PUBLIC_ASSETS_URL="https://assets.axto.dev"

# --- Credential encryption ---------------------------------------------------
# Master key for encrypting third-party credentials (Resend/PayPal/NOWPayments/
# wallet addresses) at rest in the database. Rotatable secrets live in
# /admin/settings (Admin/Super Admin only), NOT here — the vars below are only
# a bootstrap fallback used before an admin sets anything. Generate with:
# openssl rand -base64 32
APP_ENCRYPTION_KEY=""

# --- Resend (transactional email) — bootstrap fallback, prefer /admin/settings
RESEND_API_KEY=""
RESEND_FROM_EMAIL="AXTO.dev <no-reply@axto.dev>"

# --- PayPal — bootstrap fallback, prefer /admin/settings ---------------------
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_WEBHOOK_ID=""
PAYPAL_ENV="live" # "live" | "sandbox" — not a secret, stays as a plain env var

# --- NOWPayments (hosted crypto checkout) — bootstrap fallback ---------------
NOWPAYMENTS_API_KEY=""
NOWPAYMENTS_IPN_SECRET=""

# --- Crypto payments ------------------------------------------------------
# Live conversion rates are fetched from CoinGecko at quote time (no key
# required for the public price endpoint; set an API key to use the paid
# tier and avoid rate limits).
COINGECKO_API_KEY=""

# Receiving wallet addresses — bootstrap fallback only; prefer setting these
# via /admin/settings (encrypted in DB, rotatable without a redeploy). Never
# hardcoded in source. See docs/PAYMENT_WALLETS.md for the verified values
# and the mandatory manual re-verification checklist before going live.
CRYPTO_ADDRESS_BTC=""
CRYPTO_ADDRESS_ETH=""
CRYPTO_ADDRESS_BNB=""
CRYPTO_ADDRESS_SOL=""
CRYPTO_ADDRESS_USDT_TRC20=""
CRYPTO_ADDRESS_DOGE=""

# Internal secret used to sign crypto payment quotes / webhook callbacks
# generated by our own confirmation tooling (see docs/PAYMENT_WALLETS.md).
CRYPTO_WEBHOOK_SECRET="replace-with-32-byte-random-secret"

# --- Download security ------------------------------------------------------
DOWNLOAD_TOKEN_SECRET="replace-with-32-byte-random-secret"
DOWNLOAD_LINK_TTL_SECONDS="900"

# --- Admin bootstrap ---------------------------------------------------------
ADMIN_BOOTSTRAP_EMAIL="orchestraengine@gmail.com"
