// AXTO.dev — database schema
// Runs on Cloudflare D1 (SQLite) via the Prisma D1 driver adapter in
// production, and local SQLite during development — see src/lib/prisma.ts.
//
// Note: SQLite (and therefore D1) has no native enum type, so fields that
// would naturally be enums are modeled as `String` here. The allowed value
// sets live as TypeScript union types / constants in src/lib/constants.ts
// and are enforced at the application layer (zod schemas, server actions).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth (Better Auth core tables)
// ---------------------------------------------------------------------------

// Role: SUPER_ADMIN | ADMIN | EDITOR | SUPPORT | CUSTOMER
model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  emailVerified  Boolean   @default(false)
  image          String?
  role           String    @default("CUSTOMER")
  twoFactorEnabled Boolean @default(false)
  banned         Boolean   @default(false)
  banReason      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  sessions       Session[]
  accounts       Account[]
  orders         Order[]
  reviews        Review[]
  wishlist       WishlistItem[]
  downloadTokens DownloadToken[]
  downloadLogs   DownloadLog[]
  auditLogs      AuditLog[]
  notifications  Notification[]
  readingProgress ReadingProgress[]

  @@index([email])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([identifier])
  @@map("verification")
}

// ---------------------------------------------------------------------------
// Catalog
// ---------------------------------------------------------------------------

// BookStatus: DRAFT | PENDING_REVIEW | SCHEDULED | PUBLISHED | ARCHIVED | REJECTED
// LicenseType: ORIGINAL | PUBLIC_DOMAIN | PLR | MRR | ROYALTY_FREE | COMPANY_OWNED | AI_ASSISTED_ORIGINAL
// PriceTier: TIER_1_BASICS ($1-$5) | TIER_2_SKILL ($5-$15) | TIER_3_GROWTH ($15-$30)
//            | TIER_4_BUSINESS ($30-$70) | TIER_5_PREMIUM ($70-$150) | TIER_6_SUPER_PREMIUM ($150+)

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  icon        String?
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  books Book[]

  @@index([slug])
  @@map("category")
}

model Tag {
  id    String @id @default(cuid())
  slug  String @unique
  name  String

  books BookTag[]

  @@map("tag")
}

model BookTag {
  bookId String
  tagId  String

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([bookId, tagId])
  @@map("book_tag")
}

model Language {
  id     String @id @default(cuid())
  code   String @unique // en, id, zh, ja, fr, de, en-CA, ar
  name   String
  nativeName String
  rtl    Boolean @default(false)

  translations BookTranslation[]

  @@map("language")
}

// A Book is the sellable product. Its content lives per-language in
// BookTranslation so customers can pick up to two languages per purchase.
model Book {
  id           String      @id @default(cuid())
  slug         String      @unique
  categoryId   String
  priceTier    String
  priceCents   Int // canonical USD price, in cents
  compareAtCents Int?
  status       String      @default("DRAFT")
  licenseType  String
  licenseSource String?
  licenseProof  String?
  author        String     @default("AXTO.dev")
  version       String     @default("1.0.0")
  readingTimeMinutes Int?
  difficultyLevel String? // Beginner | Intermediate | Advanced
  coverImageUrl String?
  isFeatured    Boolean    @default(false)
  isBestSeller  Boolean    @default(false)
  isNew         Boolean    @default(true)
  publishedAt   DateTime?
  scheduledAt   DateTime?
  similarityScore Float?   // originality-check result vs. catalog, 0-1
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  category      Category           @relation(fields: [categoryId], references: [id])
  translations  BookTranslation[]
  tags          BookTag[]
  files         BookFile[]
  versions      BookVersion[]
  statusHistory BookStatusHistory[]
  orderItems    OrderItem[]
  reviews       Review[]
  wishlistedBy  WishlistItem[]
  downloadLogs  DownloadLog[]
  readingProgress ReadingProgress[]

  @@index([categoryId])
  @@index([status])
  @@map("book")
}

model BookTranslation {
  id          String   @id @default(cuid())
  bookId      String
  languageId  String
  title       String
  subtitle    String?
  description String
  tableOfContents String? // JSON array of chapter titles
  keywords    String? // comma separated, for search/SEO
  metaTitle   String?
  metaDescription String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  book     Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id])

  @@unique([bookId, languageId])
  @@index([bookId])
  @@map("book_translation")
}

// FileFormat: PDF | EPUB
model BookFile {
  id          String     @id @default(cuid())
  bookId      String
  languageId  String
  format      String
  storageKey  String // R2 object key (private bucket)
  sizeBytes   Int
  checksum    String // sha256, verified on upload + before each download
  isPasswordProtected Boolean @default(false)
  createdAt   DateTime   @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, languageId, format])
  @@index([bookId])
  @@map("book_file")
}

model BookVersion {
  id        String   @id @default(cuid())
  bookId    String
  version   String
  changelog String?
  createdAt DateTime @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@map("book_version")
}

model BookStatusHistory {
  id        String     @id @default(cuid())
  bookId    String
  status    String
  note      String?
  changedBy String?
  createdAt DateTime   @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@map("book_status_history")
}

// ---------------------------------------------------------------------------
// Commerce
// ---------------------------------------------------------------------------

// OrderStatus: PENDING | PAID | FAILED | REFUNDED | CANCELLED
model Order {
  id           String      @id @default(cuid())
  orderNumber  String      @unique
  userId       String
  status       String      @default("PENDING")
  subtotalCents Int
  discountCents Int        @default(0)
  totalCents   Int
  currency     String      @default("USD")
  couponId     String?
  ipAddress    String?
  country      String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  paidAt       DateTime?
  refundedAt   DateTime?

  user       User        @relation(fields: [userId], references: [id])
  coupon     Coupon?     @relation(fields: [couponId], references: [id])
  items      OrderItem[]
  payments   Payment[]
  refunds    Refund[]

  @@index([userId])
  @@index([orderNumber])
  @@map("order")
}

model OrderItem {
  id          String @id @default(cuid())
  orderId     String
  bookId      String
  unitPriceCents Int
  quantity    Int    @default(1)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  book  Book  @relation(fields: [bookId], references: [id])

  @@index([orderId])
  @@index([bookId])
  @@map("order_item")
}

// PaymentProvider: PAYPAL | CRYPTO_BTC | CRYPTO_ETH | CRYPTO_BNB | CRYPTO_SOL | CRYPTO_USDT_TRC20 | CRYPTO_DOGE
// PaymentStatus: PENDING | CONFIRMED | EXPIRED | FAILED
model Payment {
  id             String    @id @default(cuid())
  orderId        String
  provider       String
  status         String    @default("PENDING")
  amountCents    Int // USD-equivalent amount, always in cents
  providerRef    String? // PayPal order/capture id, or on-chain tx hash
  // Crypto-specific quote fields (null for PayPal)
  cryptoAsset    String?
  cryptoAddress  String?
  cryptoAmount   String? // exact decimal string, e.g. "0.00123456"
  cryptoRateUsd  String? // locked USD price per unit at quote time
  quoteExpiresAt DateTime?
  idempotencyKey String    @unique
  rawPayload     String? // JSON snapshot of the provider event, for audit
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  confirmedAt    DateTime?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([provider, status])
  @@map("payment")
}

model Refund {
  id        String   @id @default(cuid())
  orderId   String
  amountCents Int
  reason    String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  processedBy String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("refund")
}

// CouponType: PERCENTAGE | FIXED
model Coupon {
  id          String     @id @default(cuid())
  code        String     @unique
  type        String
  value       Int // percentage (0-100) or fixed cents
  maxRedemptions Int?
  redemptions Int        @default(0)
  minSubtotalCents Int   @default(0)
  startsAt    DateTime?
  expiresAt   DateTime?
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())

  orders Order[]

  @@map("coupon")
}

// ---------------------------------------------------------------------------
// Digital delivery & anti-piracy
// ---------------------------------------------------------------------------

model DownloadToken {
  id         String   @id @default(cuid())
  userId     String
  bookId     String
  languageId String
  format     String
  token      String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, bookId])
  @@map("download_token")
}

model DownloadLog {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  languageId String
  format    String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])

  @@index([userId, bookId])
  @@map("download_log")
}

// Enforces the "max two language downloads per purchased e-book" rule
// server-side, independent of DownloadLog history (which is append-only).
model LanguageEntitlement {
  id         String @id @default(cuid())
  userId     String
  bookId     String
  languageId String
  grantedAt  DateTime @default(now())

  @@unique([userId, bookId, languageId])
  @@index([userId, bookId])
  @@map("language_entitlement")
}

model ReadingProgress {
  id         String   @id @default(cuid())
  userId     String
  bookId     String
  percent    Float    @default(0)
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
  @@map("reading_progress")
}

// ---------------------------------------------------------------------------
// Reviews, wishlist, blog, notifications
// ---------------------------------------------------------------------------

model Review {
  id        String   @id @default(cuid())
  bookId    String
  userId    String
  rating    Int
  title     String?
  body      String?
  approved  Boolean  @default(true)
  createdAt DateTime @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([bookId, userId])
  @@index([bookId])
  @@map("review")
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
  @@map("wishlist_item")
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?
  content     String
  coverImageUrl String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("blog_post")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("notification")
}

// ---------------------------------------------------------------------------
// Compliance & operations
// ---------------------------------------------------------------------------

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  metadata  String? // JSON
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([action])
  @@map("audit_log")
}

model DmcaClaim {
  id           String   @id @default(cuid())
  bookId       String?
  claimantName String
  claimantEmail String
  description  String
  evidenceUrl  String?
  status       String   @default("RECEIVED") // RECEIVED | REVIEWING | UPHELD | REJECTED
  resolutionNote String?
  createdAt    DateTime @default(now())
  resolvedAt   DateTime?

  @@map("dmca_claim")
}

model SiteSetting {
  key       String   @id
  value     String // JSON-encoded
  updatedAt DateTime @updatedAt

  @@map("site_setting")
}
